"""---
## 7. Model 1 — VADER
"""

va = SentimentIntensityAnalyzer()

def vader_predict(text):
    c = va.polarity_scores(text)['compound']
    lbl = 'Positive' if c >= 0.05 else ('Negative' if c <= -0.05 else 'Neutral')
    return c, lbl

sample[['vader_score','vader_pred']] = sample['text_vader'].apply(
    lambda x: pd.Series(vader_predict(x)))

print('VADER predictions:')
print(sample['vader_pred'].value_counts())

fig, ax = plt.subplots(figsize=(10, 4))
for lbl, c in zip(['Positive','Neutral','Negative'],['#4CAF50','#FFC107','#F44336']):
    ax.hist(sample[sample['label']==lbl]['vader_score'], bins=40, alpha=0.6, label=lbl, color=c)
ax.axvline(0.05, color='green', linestyle='--', lw=1)
ax.axvline(-0.05, color='red',  linestyle='--', lw=1)
ax.set_title('VADER Compound Score by True Label')
ax.set_xlabel('Compound Score')
