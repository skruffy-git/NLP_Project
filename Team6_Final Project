# Per-class breakdown
vr = classification_report(y_true, sample['vader_pred'], labels=CLASSES,
                            output_dict=True, zero_division=0)
tr = classification_report(y_true, sample['tb_pred'],    labels=CLASSES,
                            output_dict=True, zero_division=0)

rows = []
for cls in CLASSES:
    rows.append({
        'Class': cls,
        'VADER P':  round(vr[cls]['precision'],4),
        'VADER R':  round(vr[cls]['recall'],4),
        'VADER F1': round(vr[cls]['f1-score'],4),
        'TB P':     round(tr[cls]['precision'],4),
        'TB R':     round(tr[cls]['recall'],4),
        'TB F1':    round(tr[cls]['f1-score'],4)
    })

per_class = pd.DataFrame(rows).set_index('Class')
