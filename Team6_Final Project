"""---
## 3. Labeling & Column Selection

| Rating | Label    |
|--------|----------|
| 4, 5   | Positive |
| 3      | Neutral  |
| 1, 2   | Negative |

**Columns chosen:** `reviewText` + `summary` → `combined_text`  
- `reviewText`: richest source of sentiment language  
- `summary`: user headline, often captures overall sentiment concisely  
- `overall` is **ground-truth only** — never a feature
"""

def assign_label(r):
    if r >= 4:   return 'Positive'
    elif r == 3: return 'Neutral'
    else:        return 'Negative'

df = df_raw[['reviewerID','asin','overall','reviewText','summary','len_words']].copy()
df['label']         = df['overall'].apply(assign_label)
