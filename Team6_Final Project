# Some Amazon review columns (e.g. 'style', 'image') contain dicts/lists
# which are unhashable. We filter to only hashable columns before checking.

def get_hashable_cols(df):
    """Return only columns where all values are hashable (no dicts/lists)."""
    hashable = []
    for col in df.columns:
        try:
            df[col].apply(hash)
            hashable.append(col)
        except TypeError:
            print(f"  Skipping unhashable column: '{col}'")
    return hashable

print("Identifying hashable columns...")
