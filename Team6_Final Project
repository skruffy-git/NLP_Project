"""---
## 9. Validation & Comparison
"""

CLASSES = ['Positive', 'Neutral', 'Negative']
y_true  = sample['label']

def evaluate(y_true, y_pred, name):
    print(f'\n{"="*52}\n  {name}\n{"="*52}')
    print(classification_report(y_true, y_pred, labels=CLASSES, zero_division=0))
    return (
        accuracy_score(y_true, y_pred),
        precision_score(y_true, y_pred, labels=CLASSES, average='weighted', zero_division=0),
        recall_score(y_true, y_pred, labels=CLASSES, average='weighted', zero_division=0),
        f1_score(y_true, y_pred, labels=CLASSES, average='weighted', zero_division=0)
    )

v_acc,v_prec,v_rec,v_f1 = evaluate(y_true, sample['vader_pred'], 'VADER')
t_acc,t_prec,t_rec,t_f1 = evaluate(y_true, sample['tb_pred'],    'TextBlob')

# Confusion Matrices
fig, axes = plt.subplots(1, 2, figsize=(14, 5))
for ax, y_pred, title in zip(axes,
    [sample['vader_pred'], sample['tb_pred']], ['VADER','TextBlob']):
    cm = confusion_matrix(y_true, y_pred, labels=CLASSES)
    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',
                xticklabels=CLASSES, yticklabels=CLASSES, ax=ax)
    ax.set_title(f'{title} – Confusion Matrix')
    ax.set_xlabel('Predicted')
    ax.set_ylabel('Actual')
plt.tight_layout()
plt.savefig('confusion_matrices.png', bbox_inches='tight')
plt.show()

# Summary Comparison Table
comp = pd.DataFrame({
    'Metric':   ['Accuracy','Precision (W)','Recall (W)','F1 (W)'],
    'VADER':    [round(v_acc,4), round(v_prec,4), round(v_rec,4), round(v_f1,4)],
    'TextBlob': [round(t_acc,4), round(t_prec,4), round(t_rec,4), round(t_f1,4)]
}).set_index('Metric')

print('\n=== Model Comparison Table ===')
