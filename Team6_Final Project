"""---
## 8. Model 2 — TextBlob
"""

def tb_predict(text):
    s = TextBlob(text).sentiment
    lbl = 'Positive' if s.polarity > 0.05 else ('Negative' if s.polarity < -0.05 else 'Neutral')
    return s.polarity, s.subjectivity, lbl

sample[['tb_polarity','tb_subjectivity','tb_pred']] = sample['text_textblob'].apply(
    lambda x: pd.Series(tb_predict(x)))

print('TextBlob predictions:')
